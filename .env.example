## ──────────────────────────────────────────────────────────────────────
##  AXIE DUEL — Environment variables
##  Copia este archivo a `.env` y completa los valores reales.
##  NUNCA commitees `.env` (está en .gitignore).
## ──────────────────────────────────────────────────────────────────────

## NODE
NODE_ENV=development

## ── Logging (apps/api + apps/game-server) ───────────────────────────
## Pino level: trace < debug < info < warn < error < fatal < silent.
## Default: dev=debug, prod=info. Sobreescribir si querés silenciar o ver más.
## LOG_LEVEL=info

## ── Postgres (apps/api) ──────────────────────────────────────────────
## OPCIÓN A — Docker local (`docker compose up -d`):
DATABASE_URL=postgresql://axieduel:axieduel@localhost:5432/axieduel?schema=public
##
## OPCIÓN B — Supabase cloud (recomendado):
##   En Supabase: Settings → Database → Connection pooling → Mode "Transaction"
##   - DATABASE_URL: pooler en port 6543 con ?pgbouncer=true (queries de runtime)
##   - DIRECT_URL: directa en port 5432 (Prisma migrations — DDL no funciona por pooler)
##   Ejemplo:
## DATABASE_URL="postgresql://postgres.<ref>:<PASSWORD>@aws-X-region.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=axie_duel"
## DIRECT_URL="postgresql://postgres.<ref>:<PASSWORD>@aws-X-region.pooler.supabase.com:5432/postgres?schema=axie_duel"

## ── Redis (apps/api + apps/game-server) ──────────────────────────────
## docker compose levanta redis:7 en localhost:6379, sin password.
REDIS_URL=redis://localhost:6379

## ── JWT del juego (apps/api) ─────────────────────────────────────────
## OBLIGATORIO. Generar con: openssl rand -hex 64
## Se usa para firmar los JWT propios del juego (separados de los de Waypoint).
JWT_SECRET=replace_me_with_64_random_hex_chars

## ── OAuth Web2 (LOGIN PRINCIPAL — sin wallet, sin cripto) ────────────
## Cada provider es OPCIONAL. Configurás los que quieras ofrecer.
## Si dejás vacío, /auth/<provider> devuelve 401 con code PROVIDER_DISABLED.
##
## Google:    https://console.cloud.google.com/  → APIs & Services → Credentials
##            → Create Credentials → OAuth 2.0 Client ID → Web application
##            → Authorized JavaScript origins: http://localhost:3000
##            → Authorized redirect URIs: http://localhost:3000/auth/callback/google
GOOGLE_CLIENT_ID=
## CLIENT_SECRET solo necesario si el frontend usa OAuth code flow tradicional
## (NextAuth.js, redirect → callback → token exchange). Si usás Google Identity
## Services (frontend obtiene ID token directo), no hace falta — el backend solo
## verifica el JWT con la JWK pública de Google.
## GOOGLE_CLIENT_SECRET=
##
## Vars NEXT_PUBLIC_* las consume el frontend Next.js (client-side, públicas).
## DEBEN matchear las del backend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_GAME_SERVER_URL=ws://localhost:2567
##
## Microsoft: https://entra.microsoft.com/  → App registrations → New registration
##            → Supported account types: "Accounts in any organizational directory and personal Microsoft accounts"
##            → Redirect URI (Web): http://localhost:3000/auth/callback/microsoft
MICROSOFT_CLIENT_ID=
##
## Facebook:  https://developers.facebook.com/apps/  → Create App → Type: Consumer
##            → Add Product: Facebook Login → Valid OAuth Redirect URI: http://localhost:3000/auth/callback/facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

## ── Ronin Waypoint (LINKEAR WALLET — OPCIONAL, para NFTs y premios cripto) ──
## El usuario primero se loguea con Google/Microsoft/Facebook (Web2 puro).
## DESPUÉS, desde la UI, puede linkear wallet via Waypoint → desbloquea Ranked Premium.
## Crear app en https://developers.skymavis.com/  → "App Permission" → solicitar Waypoint Account Service.
WAYPOINT_CLIENT_ID=
WAYPOINT_REDIRECT_URI=http://localhost:3000/auth/callback/waypoint
## Issuer público de Sky Mavis para verificar el JWT (JWK URL):
WAYPOINT_ISSUER=https://athena.skymavis.com

## ── Ronin Chain RPC (apps/api) ───────────────────────────────────────
## Saigon testnet por defecto. Para mainnet usar https://api.roninchain.com/rpc
RONIN_RPC_URL=https://saigon-testnet.roninchain.com/rpc
RONIN_CHAIN_ID=2021
## Contrato del Axie NFT (mainnet: 0x32950db2a7164ae833121501c797d79e7b79d74c)
AXIE_CONTRACT_ADDRESS=0x32950db2a7164ae833121501c797d79e7b79d74c

## ── Axie Infinity APIs públicas (apps/api) ───────────────────────────
AXIE_GRAPHQL_URL=https://graphql-gateway.axieinfinity.com/graphql
AXIE_GAME_API_URL=https://game-api.axie.technology

## ── Puertos ──────────────────────────────────────────────────────────
GAME_SERVER_PORT=2567
API_PORT=3001
WEB_PORT=3000

## ── CORS (apps/api + apps/game-server) ───────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

## ── Smart Contracts (packages/contracts) ─────────────────────────────
## Necesarios sólo cuando despliegues. Saigon faucet: https://faucet.roninchain.com/
DEPLOYER_PRIVATE_KEY=
SAIGON_RPC_URL=https://saigon-testnet.roninchain.com/rpc
RONIN_MAINNET_RPC_URL=https://api.roninchain.com/rpc

## ── AXS (Axie Infinity Shards) ───────────────────────────────────────
## AXS_MODE controla si el ledger es off-chain (DB) o on-chain (Ronin).
## Mientras Sky Mavis no nos dé partnership, dejar `offchain`.
##   offchain  → AxsService usa la tabla User.axsBalance (Postgres)
##   onchain   → AxsService llama al contrato AXS_TOKEN_ADDRESS vía viem
AXS_MODE=offchain
## Address del contrato. Mientras estamos en mock, deployar AxsTokenMock en Saigon
## y poner aquí su address. Cuando Sky Mavis nos dé el AXS real:
##   - Saigon testnet AXS:  (consultar con Sky Mavis)
##   - Mainnet AXS (real):  0x97a9107c1793bc407d6f527b77e7fff4d812bece
AXS_TOKEN_ADDRESS=
## Ratio de "AXS bonus" otorgado al usuario starter al primer login (off-chain).
AXS_STARTER_BONUS=100

## ── Service-to-service (game-server ↔ api) ──────────────────────────
## Token compartido para que game-server llame /internal/* del api (persistir Match al GAME_OVER).
## DEBE coincidir entre apps/api y apps/game-server. Generar con: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=dev_internal_token_min_32_chars_xxxxxxx
API_BASE_URL=http://localhost:3001
