{
  "name": "@axie-duel/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:prod": "prisma migrate deploy && node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured for api yet' && exit 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:studio": "dotenv -e ../../.env -- prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-quests": "tsx prisma/seed-quests.ts",
    "db:make-admin": "tsx prisma/make-admin.ts",
    "smoke:tournament": "tsx scripts/smoke-tournament.ts"
  },
  "dependencies": {
    "@axie-duel/card-database": "workspace:*",
    "@axie-duel/game-rules": "workspace:*",
    "@axie-duel/shared-types": "workspace:*",
    "@prisma/client": "^5.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "graphql-request": "^7.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "swagger-ui-express": "^5.0.1",
    "jose": "^5.9.3",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "viem": "^2.21.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.8",
    "@types/node": "^20.14.10",
    "@types/swagger-ui-express": "^4.1.7",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.20.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2",
    "vitest-mock-extended": "^2.0.2"
  }
}
