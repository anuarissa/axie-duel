// Prisma schema — Axie Duel API
// Master prompt sección 7. PostgreSQL + Prisma 5.x.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase + cualquier setup con connection pooler (PgBouncer) requiere
  // un canal "directo" para migraciones (Prisma no puede correr DDL via pooler
  // en Transaction mode). Si DIRECT_URL no se setea, Prisma cae a `url`.
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String?       @unique
  emailVerified Boolean       @default(false)
  username      String        @unique
  /// Display name del provider (ej: "Anuar Issa" desde Google).
  displayName   String?
  avatarUrl     String?
  // ── Providers Web2 (cualquiera basta para iniciar sesión, NO requiere wallet) ──
  /// `sub` de Google ID Token. NULL si nunca usó Google.
  googleSub     String?       @unique
  /// `oid` de Microsoft ID Token. NULL si nunca usó Microsoft.
  microsoftSub  String?       @unique
  /// User ID de Facebook Graph API. NULL si nunca usó Facebook.
  facebookSub   String?       @unique
  // ── Web3: TODO opcional, se setea al linkear wallet desde la UI ──────
  /// `sub` del JWT de Waypoint. NULL si no linkeó wallet vía Waypoint.
  waypointSub   String?       @unique
  /// Address EVM (Ronin). NULL = jugador 100% Web2 sin wallet linkeada.
  walletAddress String?       @unique
  hasNFTAxies   Boolean       @default(false)
  /// true = puede acceder a /admin/* (crear torneos, kickear users, etc.).
  /// Se promueve manualmente: `pnpm --filter @axie-duel/api db:make-admin <username>`.
  isAdmin       Boolean       @default(false)
  eloRanked     Int           @default(1000)
  eloRankedNFT  Int           @default(1000)
  level         Int           @default(1)
  xp            Int           @default(0)
  /// Balance off-chain de AXS (ficticio mientras no haya partnership con Sky Mavis).
  /// Cuando se active modo on-chain, este campo se usa solo como cache; la verdad vive en Ronin.
  axsBalance    Decimal       @default(0) @db.Decimal(36, 18)
  starterAxies  StarterAxie[]
  decks         Deck[]
  matches       Match[]       @relation("PlayerMatches")
  ownedCards    OwnedCard[]
  axsTxs        AxsTransaction[]
  tournamentRegs TournamentParticipant[]
  questProgress UserQuestProgress[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([eloRanked])
  @@index([eloRankedNFT])
  @@index([axsBalance])
}

/// Ledger inmutable de TODA mutación al `axsBalance` de un usuario.
/// Earn = amount > 0. Burn = amount < 0. Single source of truth de auditoría.
model AxsTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 'EARN_TOURNAMENT' | 'EARN_DAILY' | 'EARN_STARTER_BONUS' |
  /// 'BURN_TOURNAMENT_ENTRY' | 'BURN_NFT_MINT' | 'BURN_COSMETIC' | 'BURN_DECK_SLOT'
  kind      String
  amount    Decimal  @db.Decimal(36, 18) // signed: positivo=earn, negativo=burn
  /// Razón legible: 'tournament:<id>' | 'cosmetic:<sku>' | 'mint:<cardId>' | 'daily:<date>'
  reason    String
  /// Hash de tx on-chain. null mientras estemos off-chain.
  txHash    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([kind])
}

model Tournament {
  id                    String                  @id @default(cuid())
  name                  String
  description           String?
  /// 'SINGLE_ELIM' (Fase 0) | 'SWISS' (Fase 3) | 'ROUND_ROBIN'
  format                String                  @default("SINGLE_ELIM")
  /// 'SCHEDULED' | 'REGISTRATION' | 'IN_PROGRESS' | 'COMPLETED' | 'CANCELLED'
  status                String                  @default("SCHEDULED")
  entryCostAxs          Decimal                 @default(0) @db.Decimal(36, 18)
  prizePoolAxs          Decimal                 @default(0) @db.Decimal(36, 18)
  /// JSON: [{rank: 1, share: 0.5}, {rank: 2, share: 0.3}, {rank: 3, share: 0.2}]
  /// `share` debe sumar 1. El servicio reparte prizePoolAxs * share al rank correspondiente.
  prizeDistribution     Json
  maxParticipants       Int                     @default(64)
  /// Si true, requiere que al menos 3 Axies NFT estén en el deck del jugador.
  requiresNFTAxies      Boolean                 @default(false)
  registrationDeadline  DateTime
  startsAt              DateTime
  endsAt                DateTime?
  participants          TournamentParticipant[]
  matches               TournamentMatch[]
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  @@index([status, startsAt])
}

model TournamentParticipant {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  registeredAt DateTime   @default(now())
  /// Set tras `complete()`. 1 = ganador, 2 = finalista, etc.
  finalRank    Int?
  /// Para Swiss (Fase 3) — puntos acumulados.
  totalPoints  Int        @default(0)
  wins         Int        @default(0)
  losses       Int        @default(0)
  /// Si fue eliminado por bracket (single-elim). En Swiss este campo no aplica.
  eliminated   Boolean    @default(false)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
}

model TournamentMatch {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        Int
  bracketSlot  Int        @default(0)
  player1Id    String
  /// null = bye automático, gana player1.
  player2Id    String?
  winnerId     String?
  player1Score Int        @default(0)
  player2Score Int        @default(0)
  /// FK al Match real cuando se juega. Sin FK (Match es independiente).
  matchId      String?
  /// 'PENDING' | 'IN_PROGRESS' | 'COMPLETED' | 'BYE' | 'WALKOVER'
  status       String     @default("PENDING")
  scheduledAt  DateTime?
  finishedAt   DateTime?
  createdAt    DateTime   @default(now())

  @@index([tournamentId, round])
  @@index([player1Id])
  @@index([player2Id])
}

model StarterAxie {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  axieClass String
  parts     Json    // {eyes, ears, mouth, horn, back, tail}
  stats     Json    // {hp, speed, skill, morale}
  isStarter Boolean @default(true)

  @@index([userId])
}

model Card {
  id          String      @id // ID estable de catálogo (ej: 'mon_beast_001')
  name        String
  type        String      // 'Monster' | 'Spell' | 'Trap'
  subType     String?
  rarity      String
  attribute   String?
  level       Int?
  atk         Int?
  def         Int?
  effectJson  Json
  imageUrl    String
  description String
  ownedBy     OwnedCard[]
  decks       DeckCard[]
}

model OwnedCard {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId     String
  card       Card     @relation(fields: [cardId], references: [id])
  isNFT      Boolean  @default(false)
  tokenId    String?  // si es NFT (Ronin tokenId)
  obtainedAt DateTime @default(now())

  @@unique([userId, cardId, tokenId])
  @@index([userId])
}

model Deck {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  format    String     // 'Standard' | 'Premium'
  cards     DeckCard[]
  isActive  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
}

model DeckCard {
  id       String @id @default(cuid())
  deckId   String
  deck     Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)
  cardId   String
  card     Card   @relation(fields: [cardId], references: [id])
  zone     String // 'Main' | 'Extra' | 'Side'
  quantity Int

  @@index([deckId])
}

model Match {
  id          String    @id @default(cuid())
  player1Id   String
  player2Id   String?   // null si es PvE
  winnerId    String?
  mode        String    // 'PvE' | 'PvP_Casual' | 'PvP_Ranked' | 'PvP_RankedNFT'
  duration    Int       // segundos
  turnsPlayed Int
  /// URL externa al replay (S3, Supabase Storage). Para Fase 3 cuando los logs sean grandes.
  replayUrl   String?
  /// Log determinista de eventos del duelo. Para Fase 0 inline en JSONB.
  /// Cada entrada: `{ ts, type, playerId?, data? }`. Combinado con rngSeed + decklists iniciales,
  /// permite reconstruir el duelo paso a paso.
  replayLog   Json?
  /// 'LIFE_POINTS_ZERO' | 'DECK_OUT' | 'SURRENDER' | 'DISCONNECT_TIMEOUT' | 'SPECIAL_CARD_CONDITION'
  reason      String?
  /// Delta de ELO aplicado al ranked match. JSON: { player1: +12, player2: -12 }.
  /// null si el match no era ranked.
  eloDeltas   Json?
  finishedAt  DateTime?
  createdAt   DateTime  @default(now())
  players     User[]    @relation("PlayerMatches")

  @@index([player1Id])
  @@index([mode, finishedAt])
}

/// Quest disponible por una ventana de tiempo. El sistema crea quests cada día
/// (cron en Fase 3 — manual con `pnpm db:seed-quests` por ahora).
/// Cada User tiene su propio progreso vía UserQuestProgress.
model DailyQuest {
  id          String              @id @default(cuid())
  /// Tipo de meta. Determina qué evento incrementa el progreso:
  ///   'WIN_PVE' | 'WIN_PVP' | 'PLAY_GAMES' | 'COMPLETE_TOURNAMENT'
  kind        String
  /// Goal numérico (ej: ganar 3 PvE → target=3).
  target      Int
  /// AXS otorgados al claim.
  rewardAxs   Decimal             @db.Decimal(36, 18)
  description String
  validFrom   DateTime
  validUntil  DateTime
  progress    UserQuestProgress[]
  createdAt   DateTime            @default(now())

  @@index([kind, validUntil])
}

model UserQuestProgress {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId     String
  quest       DailyQuest @relation(fields: [questId], references: [id], onDelete: Cascade)
  current     Int        @default(0)
  completed   Boolean    @default(false)
  /// true cuando el usuario ya reclamó el AXS premio. Idempotente.
  claimed     Boolean    @default(false)
  completedAt DateTime?
  claimedAt   DateTime?
  updatedAt   DateTime   @updatedAt

  @@unique([userId, questId])
  @@index([userId])
}
