{
  "name": "axie-duel",
  "version": "0.1.0",
  "private": true,
  "description": "Axie Duel — TCG Web3 (Yu-Gi-Oh!-style) on Ronin",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "db:migrate": "pnpm --filter @axie-duel/api prisma:migrate",
    "db:generate": "pnpm --filter @axie-duel/api prisma:generate",
    "db:seed": "pnpm --filter @axie-duel/api db:seed",
    "db:make-admin": "pnpm --filter @axie-duel/api db:make-admin",
    "db:studio": "pnpm --filter @axie-duel/api prisma:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
