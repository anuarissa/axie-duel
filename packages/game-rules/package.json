{
  "name": "@axie-duel/game-rules",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'no lint configured for game-rules yet' && exit 0",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo coverage"
  },
  "dependencies": {
    "@axie-duel/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
